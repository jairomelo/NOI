---
interface Props {
  title?: string;
}
const { title = 'A Postcard Collection' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    {/* Sync script: sets html[lang] from localStorage BEFORE first paint — no flash */}
    <script is:inline>
      (function(){
        var l = localStorage.getItem('lang');
        if (l === 'es') document.documentElement.lang = 'es';
      })();
    </script>
  </head>
  <body>
    <header>
      <nav>
        <a class="site-title" href={base}>A Postcard Collection</a>
        <ul>
          <li><a href={`${base}grid`}><span data-lang="en">All objects</span><span data-lang="es">Todos los objetos</span></a></li>
          <li><a href={`${base}route`}><span data-lang="en">A route</span><span data-lang="es">Una ruta</span></a></li>
          <li><a href={`${base}story/frankfurter-hof`}><span data-lang="en">Story</span><span data-lang="es">Historia</span></a></li>
          <li><a href={`${base}about`}><span data-lang="en">About</span><span data-lang="es">Acerca de</span></a></li>
          <li>
            <button id="lang-toggle" class="lang-toggle" title="Switch language">
              <span id="lang-btn-en">EN</span><span class="lang-sep">|</span><span id="lang-btn-es">ES</span>
            </button>
          </li>
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        <span data-lang="en">A Postcard Collection from Early 20th century</span>
        <span data-lang="es">Una colección de postales de principios del siglo XX</span>
      </p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:          #141210;
    --surface:     #1f1c19;
    --border:      #3a342d;
    --text:        #f0e8da;
    --muted:       #9a8c7e;
    --accent:      #c9964a;
    --accent-h:    #e0b06a;
    --radius:      6px;
    --font-serif:  Georgia, 'Times New Roman', serif;
    --font-sans:   system-ui, -apple-system, sans-serif;
  }

  html { background: var(--bg); color: var(--text); font-family: var(--font-sans); }
  body { min-height: 100vh; display: flex; flex-direction: column; }
  img  { display: block; max-width: 100%; }
  a    { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--accent-h); text-decoration: underline; }

  header {
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    gap: 2rem;
  }
  .site-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--text);
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .site-title:hover { text-decoration: none; color: var(--accent-h); }
  nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }
  nav ul a {
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  nav ul a:hover { color: var(--text); text-decoration: none; }

  /* i18n: hide both lang variants, show only the active one */
  [data-lang] { display: none; }
  html[lang="en"] [data-lang="en"] { display: revert; }
  html[lang="es"] [data-lang="es"] { display: revert; }

  /* Language toggle button */
  .lang-toggle {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.2rem 0.45rem;
    font-size: 0.68rem;
    color: var(--muted);
    cursor: pointer;
    letter-spacing: 0.06em;
    display: flex;
    gap: 3px;
    align-items: center;
  }
  .lang-toggle:hover { border-color: var(--accent); color: var(--text); }
  .lang-sep { opacity: 0.35; }
  #lang-btn-en, #lang-btn-es { transition: opacity 0.2s; }
  html[lang="en"] #lang-btn-en { color: var(--accent); font-weight: 700; }
  html[lang="en"] #lang-btn-es { opacity: 0.4; }
  html[lang="es"] #lang-btn-es { color: var(--accent); font-weight: 700; }
  html[lang="es"] #lang-btn-en { opacity: 0.4; }

  main { flex: 1; }

  footer {
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 1rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
</style>

<script>
  // Language toggle — runs once per page load
  const toggle = document.getElementById('lang-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const next = document.documentElement.lang === 'es' ? 'en' : 'es';
      document.documentElement.lang = next;
      localStorage.setItem('lang', next);
    });
  }
</script>
