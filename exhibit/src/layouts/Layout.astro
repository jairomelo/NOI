---
interface Props {
  title?: string;
}
const { title = 'Colección Campero' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header>
      <nav>
        <a class="site-title" href={base}>Colección Campero</a>
        <ul>
          <li><a href={`${base}grid`}>Todos los objetos</a></li>
          <li><a href={`${base}route`}>Una ruta</a></li>
          <li><a href={`${base}story/frankfurter-hof`}>Historia</a></li>
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Colección de postales de Manuel Campero · Principios del siglo XX</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:          #141210;
    --surface:     #1f1c19;
    --border:      #3a342d;
    --text:        #f0e8da;
    --muted:       #9a8c7e;
    --accent:      #c9964a;
    --accent-h:    #e0b06a;
    --radius:      6px;
    --font-serif:  Georgia, 'Times New Roman', serif;
    --font-sans:   system-ui, -apple-system, sans-serif;
  }

  html { background: var(--bg); color: var(--text); font-family: var(--font-sans); }
  body { min-height: 100vh; display: flex; flex-direction: column; }
  img  { display: block; max-width: 100%; }
  a    { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--accent-h); text-decoration: underline; }

  header {
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    gap: 2rem;
  }
  .site-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--text);
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .site-title:hover { text-decoration: none; color: var(--accent-h); }
  nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }
  nav ul a {
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  nav ul a:hover { color: var(--text); text-decoration: none; }

  main { flex: 1; }

  footer {
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 1rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
</style>
