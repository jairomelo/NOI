---
import { marked } from 'marked';

interface Props {
  card: any;
  base: string;
}
const { card, base } = Astro.props;

const transcriptionHtml = (() => {
  const t = card.transcription_back || card.transcription_front;
  if (!t) return null;
  return marked.parse(t);
})();

const LANG_NAMES_EN: Record<string, string> = {
  it: 'Italian', fr: 'French', de: 'German', en: 'English',
  es: 'Spanish', ru: 'Russian', nl: 'Dutch',
};
const LANG_NAMES_ES: Record<string, string> = {
  it: 'Italiano', fr: 'Francés', de: 'Alemán', en: 'Inglés',
  es: 'Español', ru: 'Ruso', nl: 'Neerlandés',
};

function langLabel(code: string | null, names: Record<string, string>): string {
  if (!code) return '';
  const primary = code.split(/[;,\s]/)[0].trim().toLowerCase();
  return names[primary] ?? code;
}
---

<article class="meta-panel">
  <h1 class="meta-title">{card.title}</h1>

  <dl class="meta-list">
    {card.date && (
      <div class="meta-row">
        <dt><span data-lang="en">Year</span><span data-lang="es">Año</span></dt>
        <dd>{card.date}</dd>
      </div>
    )}
    {card.location && (
      <div class="meta-row">
        <dt><span data-lang="en">Place</span><span data-lang="es">Lugar</span></dt>
        <dd>
          {(card.latitude && card.longitude)
            ? <a
                href={`https://www.openstreetmap.org/?mlat=${card.latitude}&mlon=${card.longitude}#map=14/${card.latitude}/${card.longitude}`}
                target="_blank"
                rel="noopener"
              >{card.location} ↗</a>
            : card.location
          }
        </dd>
      </div>
    )}
    {card.language && (
      <div class="meta-row">
        <dt><span data-lang="en">Language</span><span data-lang="es">Idioma</span></dt>
        <dd>
          <span data-lang="en">{langLabel(card.language, LANG_NAMES_EN)}</span>
          <span data-lang="es">{langLabel(card.language, LANG_NAMES_ES)}</span>
        </dd>
      </div>
    )}
    {card.source && (
      <div class="meta-row">
        <dt><span data-lang="en">Source</span><span data-lang="es">Fuente</span></dt>
        <dd>{card.source}</dd>
      </div>
    )}
  </dl>

  {card.description && (
    <blockquote class="meta-description">{card.description}</blockquote>
  )}

  {transcriptionHtml && (
    <div class="meta-transcription">
      <p class="meta-transcription__label">
        <span data-lang="en">Handwritten text</span>
        <span data-lang="es">Texto manuscrito</span>
      </p>
      <div class="meta-transcription__body" set:html={transcriptionHtml} />
    </div>
  )}

  {card.subjects?.length > 0 && (
    <div class="meta-subjects">
      {card.subjects.map((s: string) => (
        <a class="tag" href={`${base}grid?subject=${encodeURIComponent(s)}`}>{s}</a>
      ))}
    </div>
  )}

  {card.color_hex && (
    <div class="meta-color">
      <span class="color-swatch" style={`background:${card.color_hex}`}></span>
      <span><span data-lang="en">Dominant colour</span><span data-lang="es">Color dominante</span></span>
    </div>
  )}

  <nav class="meta-nav">
    <a href={`${base}grid`}><span data-lang="en">← Back to collection</span><span data-lang="es">← Volver a la colección</span></a>
    <a href={`${base}route`}><span data-lang="en">View on map →</span><span data-lang="es">Ver en el mapa →</span></a>
  </nav>
</article>

<style>
  .meta-panel { padding: 0.25rem 0; }

  .meta-title {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .meta-list { display: grid; gap: 0.55rem; margin-bottom: 1.5rem; }

  .meta-row {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 0.5rem;
    font-size: 0.875rem;
  }
  dt { color: var(--muted); padding-top: 0.05em; }
  dd { color: var(--text); }
  dd a { color: var(--accent); }
  dd a:hover { color: var(--accent-h); }

  .meta-description {
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--text);
    padding: 1.1rem 1.25rem;
    background: var(--surface);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 1.5rem;
  }

  .meta-transcription {
    background: #1e1a14;
    border: 1px solid #3a3020;
    border-radius: var(--radius);
    padding: 1rem 1.25rem 1.1rem;
    margin-bottom: 1.5rem;
  }
  .meta-transcription__label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a08c60;
    margin: 0 0 0.75rem;
  }
  .meta-transcription__body {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 0.92rem;
    line-height: 1.9;
    color: #d4c9a8;
  }
  .meta-transcription__body p { margin: 0 0 0.6em; }
  .meta-transcription__body p:last-child { margin-bottom: 0; }
  .meta-transcription__body em { font-style: italic; color: #c4b898; }
  .meta-transcription__body strong { font-weight: 600; color: #e0d5b5; }

  .meta-subjects {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .tag {
    font-size: 0.73rem;
    padding: 0.2rem 0.6rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    transition: border-color 0.15s, color 0.15s;
  }
  .tag:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

  .meta-color {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }
  .color-swatch {
    display: inline-block;
    width: 18px; height: 18px;
    border-radius: 3px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .meta-nav {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    font-size: 0.82rem;
  }
  .meta-nav a { color: var(--muted); }
  .meta-nav a:hover { color: var(--text); text-decoration: none; }
</style>
