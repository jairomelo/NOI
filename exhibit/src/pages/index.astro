---
import Layout from '../layouts/Layout.astro';
import postcards from '../data/postcards.json';

const base = import.meta.env.BASE_URL;

// Pick one representative card per exhibit mode
const storyCard = postcards.find(p => p.image_front && p.description) ?? postcards[0];
const gridCard  = postcards.find(p => p.image_thumb && p.color_hue && p.color_hue > 30) ?? postcards[10];
const routeCard = postcards.find(p => p.image_front && p.latitude)  ?? postcards[5];

const img = (name: string) => `${base}images/${name}`;
---

<Layout title="Colección Campero — Exhibit">
  <section class="hero">
    <p class="hero-eyebrow">Una colección · Tres modos de leer</p>
    <h1>Postales de principios del siglo XX</h1>
    <p class="hero-sub">
      Documentos históricos como herramientas de narración.
      Elige cómo quieres explorar la colección.
    </p>
  </section>

  <section class="modes">
    <a class="mode-card" href={`${base}detail/${storyCard.objectid}`}>
      <div
        class="mode-card__img"
        style={`background-image:url('${img(storyCard.image_front)}')`}
      ></div>
      <div class="mode-card__body">
        <span class="mode-label">I</span>
        <h2>Un solo objeto</h2>
        <p>Lee despacio una postal. Sus edificios, sus personas, el mensaje en el dorso.</p>
        <span class="mode-cta">Explorar →</span>
      </div>
    </a>

    <a class="mode-card" href={`${base}grid`}>
      <div
        class="mode-card__img"
        style={`background-image:url('${img(gridCard.image_thumb)}')`}
      ></div>
      <div class="mode-card__body">
        <span class="mode-label">II</span>
        <h2>Todos los objetos</h2>
        <p>Ver la colección entera de un vistazo. Filtrar por color, tema o idioma.</p>
        <span class="mode-cta">Ver colección →</span>
      </div>
    </a>

    <a class="mode-card" href={`${base}route`}>
      <div
        class="mode-card__img"
        style={`background-image:url('${img(routeCard.image_front)}')`}
      ></div>
      <div class="mode-card__body">
        <span class="mode-label">III</span>
        <h2>Una ruta</h2>
        <p>Sigue las postales por el mapa. Un día en un lugar, ayer y hoy.</p>
        <span class="mode-cta">Ver mapa →</span>
      </div>
    </a>
  </section>
</Layout>

<style>
  .hero {
    max-width: 720px;
    margin: 5rem auto 3.5rem;
    padding: 0 1.5rem;
    text-align: center;
  }
  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 0.9rem;
  }
  .hero-sub {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .modes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5px;
    background: var(--border);
    max-width: 1200px;
    margin: 0 auto 5rem;
    overflow: hidden;
  }

  .mode-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    overflow: hidden;
    transition: background 0.2s;
  }
  .mode-card:hover { background: #262119; text-decoration: none; }

  .mode-card__img {
    height: 260px;
    background-size: cover;
    background-position: center;
    background-color: var(--border);
    transition: transform 0.4s;
    transform-origin: center;
  }
  .mode-card:hover .mode-card__img { transform: scale(1.04); }

  .mode-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .mode-label {
    font-family: var(--font-serif);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .mode-card__body h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
  }
  .mode-card__body p {
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.65;
    flex: 1;
  }
  .mode-cta {
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
    transition: color 0.15s;
  }
  .mode-card:hover .mode-cta { color: var(--accent-h); }
</style>

