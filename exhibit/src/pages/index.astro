---
import Layout from '../layouts/Layout.astro';
import postcards from '../data/postcards.json';

const base = import.meta.env.BASE_URL;

// Pick one representative card per exhibit mode
const storyCard = postcards.find(p => p.image_front && p.description) ?? postcards[101];
const gridCard  = postcards.find(p => p.image_thumb && p.color_hue && p.color_hue > 30) ?? postcards[10];
const routeCard = postcards.find(p => p.image_front && p.latitude)  ?? postcards[5];

const img = (name: string) => `${base}images/${name}`;
---

<Layout title="A Postcard Collection — Exhibit">
  <section class="hero">
    <p class="hero-eyebrow"><span data-lang="en">A collection · Three ways to read</span><span data-lang="es">Una colección · Tres modos de leer</span></p>
    <h1><span data-lang="en">Postcards from the early 20th century</span><span data-lang="es">Postales de principios del siglo XX</span></h1>
    <p class="hero-sub">
      <span data-lang="en">Historical documents as storytelling tools. Choose how you want to explore the collection.</span>
      <span data-lang="es">Documentos históricos como herramientas de narración. Elige cómo quieres explorar la colección.</span>
    </p>
  </section>

  <section class="modes">
    <a class="mode-card" href={`${base}story/frankfurter-hof`}>
      <div
        class="mode-card__img"
        style={`background-image:url('${base}images/ui/story_view.gif')`}
      ></div>
      <div class="mode-card__body">
        <span class="mode-label">I</span>
        <h2><span data-lang="en">A single story</span><span data-lang="es">Una sola historia</span></h2>
        <p><span data-lang="en">What story does a postcard tell?</span><span data-lang="es">¿Qué historia nos cuenta una postal?</span></p>
        <span class="mode-cta"><span data-lang="en">Explore →</span><span data-lang="es">Explorar →</span></span>
      </div>
    </a>

    <a class="mode-card" href={`${base}grid`}>
      <div
        class="mode-card__img"
        style={`background-image:url('${base}images/ui/grid_img.gif')`}
      ></div>
      <div class="mode-card__body">
        <span class="mode-label">II</span>
        <h2><span data-lang="en">All objects</span><span data-lang="es">Todos los objetos</span></h2>
        <p><span data-lang="en">See the entire collection at a glance. Filter by colour, subject or language.</span><span data-lang="es">Ver la colección entera de un vistazo. Filtrar por color, tema o idioma.</span></p>
        <span class="mode-cta"><span data-lang="en">Browse collection →</span><span data-lang="es">Ver colección →</span></span>
      </div>
    </a>

    <a class="mode-card" href={`${base}route`}>
      <div
        class="mode-card__img"
        style={`background-image:url('${base}images/ui/route_img.gif')`}
      ></div>
      <div class="mode-card__body">
        <span class="mode-label">III</span>
        <h2><span data-lang="en">A route</span><span data-lang="es">Una ruta</span></h2>
        <p><span data-lang="en">Follow the postcards on the map. A place, yesterday and today.</span><span data-lang="es">Sigue las postales por el mapa. Un lugar, ayer y hoy.</span></p>
        <span class="mode-cta"><span data-lang="en">View map →</span><span data-lang="es">Ver mapa →</span></span>
      </div>
    </a>
  </section>
</Layout>

<style>
  .hero {
    max-width: 720px;
    margin: 5rem auto 3.5rem;
    padding: 0 1.5rem;
    text-align: center;
  }
  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 0.9rem;
  }
  .hero-sub {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .modes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5px;
    background: var(--border);
    max-width: 1200px;
    margin: 0 auto 5rem;
    overflow: hidden;
  }

  .mode-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    overflow: hidden;
    transition: background 0.2s;
  }
  .mode-card:hover { background: #262119; text-decoration: none; }

  .mode-card__img {
    height: 260px;
    background-size: cover;
    background-position: center;
    background-color: var(--border);
    transition: transform 0.4s;
    transform-origin: center;
  }
  .mode-card:hover .mode-card__img { transform: scale(1.04); }

  .mode-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .mode-label {
    font-family: var(--font-serif);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .mode-card__body h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
  }
  .mode-card__body p {
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.65;
    flex: 1;
  }
  .mode-cta {
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
    transition: color 0.15s;
  }
  .mode-card:hover .mode-cta { color: var(--accent-h); }
</style>

