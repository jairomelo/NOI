---
import Layout from '../layouts/Layout.astro';
import ObjectGrid from '../components/ObjectGrid.jsx';
import postcards from '../data/postcards.json';

const base = import.meta.env.BASE_URL;

// Only pass fields the grid needs (keeps serialized prop lean)
const gridData = postcards.map(({
  objectid, title, date, language, subjects,
  image_thumb, image_back, color_hex, color_hue, color_palette,
}) => ({ objectid, title, date, language, subjects, image_thumb, image_back, color_hex, color_hue, color_palette }));
---

<Layout title="All Objects">
  <div class="grid-page">
    <header class="page-header">
      <h1>All Objects</h1>
      <p>{postcards.length} postcards</p>
    </header>
    <ObjectGrid postcards={gridData} base={base} client:load />
  </div>
</Layout>

<style>
  .grid-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 400;
  }
  .page-header p {
    color: var(--muted);
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }
</style>
