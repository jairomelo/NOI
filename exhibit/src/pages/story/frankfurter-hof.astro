---
import Layout from '../../layouts/Layout.astro';
import StoryViewer from '../../components/StoryViewer.jsx';
import story from '../../data/stories/frankfurter-hof.json';

const base = import.meta.env.BASE_URL;
---

<Layout title={`${story.title} — Historia`}>
  <!-- Story header -->
  <div class="story-header">
    <p class="story-header__eyebrow"><span data-lang="en">Story</span><span data-lang="es">Historia</span></p>
    <h1 class="story-header__title">{story.title}</h1>
    <p class="story-header__subtitle">{story.subtitle}</p>
  </div>

  <section class="story-body">
    <StoryViewer
      chapters={story.chapters}
      base={base}
      client:load
    />
  </section>

  <!-- Footer nav: link to the underlying card detail page -->
  <div class="story-footer">
    <p class="story-footer__hint">
      <span data-lang="en">Explore the full collection in <a href={`${base}grid`}>All objects</a> or take the geographical tour in <a href={`${base}route`}>A route</a>.</span>
      <span data-lang="es">Explora toda la colección en <a href={`${base}grid`}>Todos los objetos</a> o el recorrido geográfico en <a href={`${base}route`}>Una ruta</a>.</span>
    </p>
  </div>
</Layout>

<style>
  /* Story header ----------------------------------------------------------- */
  .story-header {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2rem;
    text-align: center;
  }
  .story-header__eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .story-header__title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 0.75rem;
  }
  .story-header__subtitle {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Story body: full-width so the viewer can use the whole viewport -------- */
  .story-body {
    border-top: 1px solid var(--border);
  }

  /* The StoryViewer island expands: image panel 56%, cards 44% ------------ */
  .story-body :global(.story-image-panel) {
    width: 56%;
  }
  .story-body :global(.story-cards-panel) {
    width: 44%;
  }

  /* Mobile: stack image on top, cards below */
  @media (max-width: 700px) {
    .story-body :global(.story-image-panel) {
      position: relative !important;
      top: 0 !important;
      height: 55vw !important;
      width: 100% !important;
    }
    .story-body :global(.story-cards-panel) {
      width: 100% !important;
    }
  }

  /* Footer nav ------------------------------------------------------------ */
  .story-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    text-align: center;
  }
  .story-footer__hint {
    font-size: 0.82rem;
    color: var(--muted);
  }
</style>
